<resources>
    <!-- Base application theme -->
    <style name="Base.Theme.MyFirstApp" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:windowTranslucentStatus">false</item>

        <!-- This makes the 'pill' indicator behind the icon white -->
        <item name="colorPrimaryContainer">#FFFFFF</item>
        <item name="colorOnPrimaryContainer">#000000</item>
    </style>

    <style name="Theme.MyFirstApp" parent="Base.Theme.MyFirstApp" />

    <style name="StaffBottomNavLabel" parent="TextAppearance.Material3.LabelMedium">
        <item name="android:textColor">#000000</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <!-- This style is referenced in your layout XML -->
    <style name="App.CustomIndicator" parent="Widget.Material3.BottomNavigationView.ActiveIndicator">
        <item name="android:color">#FFFFFF</item>
        <item name="android:width">44dp</item>
        <item name="android:height">32dp</item>
    </style>

    <!-- Corner Styles -->
    <style name="RoundedCornersLarge" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">24dp</item>
    </style>

    <style name="RoundedCornersMedium" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">16dp</item>
    </style>

    <style name="RoundedCorners" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">12dp</item>
    </style>
</resources>