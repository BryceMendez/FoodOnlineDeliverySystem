<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">

    <!-- The original content is now inside this container to match your other pages -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- UPPER BAR -->
        <LinearLayout
            android:id="@+id/upper_navigation_bar"
            android:layout_width="match_parent"
            android:layout_height="61dp"
            android:background="#800000"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">
            <ImageView
                android:layout_width="20dp"
                android:layout_height="wrap_content"
                android:src="@drawable/ic_back"
                app:tint="#FFFFFF" />
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="My Vouchers"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- TAB BUTTONS (Active/Past) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:orientation="horizontal"
            android:background="#FFFFFF">

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnActiveVoucher"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="Active Voucher"
                android:textAllCaps="false"
                android:textColor="@color/tab_text_selector"
                android:background="@drawable/tab_background_selector"
                app:backgroundTint="@null"
                android:stateListAnimator="@null"
                android:elevation="0dp" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnPastVouchers"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="Past Vouchers"
                android:textAllCaps="false"
                android:textColor="@color/tab_text_selector"
                android:background="@drawable/tab_background_selector"
                app:backgroundTint="@null"
                android:stateListAnimator="@null"
                android:elevation="0dp" />
        </LinearLayout>

        <!-- DETAILS TEXT -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingLeft="16dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:text="Tap to view details"
            android:textColor="#808080"
            android:textSize="14sp" />

        <!-- ADD VOUCHER BUTTON -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAddVoucher"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_margin="16dp"
            android:backgroundTint="#800000"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:text="Add Voucher"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            app:cornerRadius="0dp"
            app:icon="@drawable/ic_add"
            app:iconGravity="textStart"
            app:iconTint="@color/white" />

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <!-- Content goes here -->
        </ScrollView>

    </LinearLayout>

</androidx.drawerlayout.widget.DrawerLayout>