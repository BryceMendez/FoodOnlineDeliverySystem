<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">

    <!-- Content container to match Home Page hierarchy -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- UPPER BAR -->
        <LinearLayout
            android:id="@+id/upper_navigation_bar"
            android:layout_width="0dp"
            android:layout_height="61dp"
            android:background="#800000"
            android:elevation="8dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:layout_width="40dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_menu" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="Menu"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold" />

            <ImageView
                android:layout_width="40dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_cart" />
        </LinearLayout>

        <androidx.core.widget.NestedScrollView
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:fillViewport="true"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/upper_navigation_bar">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingBottom="16dp">

                <!-- MAIN BANNER -->
                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/banner_two"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_marginTop="16dp"
                    android:layout_marginEnd="16dp"
                    android:adjustViewBounds="true"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:shapeAppearanceOverlay="@style/RoundedCornersLarge"
                    app:srcCompat="@drawable/banner_two" />

                <!-- TEXT NAVIGATION -->
                <LinearLayout
                    android:id="@+id/text_nav_container"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:orientation="horizontal"
                    app:layout_constraintEnd_toEndOf="@id/banner_two"
                    app:layout_constraintStart_toStartOf="@id/banner_two"
                    app:layout_constraintTop_toBottomOf="@id/banner_two">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:textColor="#000000" android:text="Menu" android:textStyle="bold" />
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:textColor="#000000" android:text="Promos" android:textStyle="bold" />
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:textColor="#000000" android:text="Deals" android:textStyle="bold" />
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:textColor="#000000" android:text="Pizza" android:textStyle="bold" />
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1.2" android:gravity="center" android:textColor="#000000" android:text="Group Meals" android:textStyle="bold" />
                </LinearLayout>

                <!-- ROW 1 -->
                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/img_promo"
                    android:layout_width="0dp"
                    android:layout_height="160dp"
                    android:layout_marginTop="20dp"
                    android:layout_marginEnd="8dp"
                    android:elevation="6dp"
                    android:padding="2dp"
                    android:scaleType="centerCrop"
                    app:layout_constraintEnd_toStartOf="@+id/img_chicken"
                    app:layout_constraintStart_toStartOf="@id/banner_two"
                    app:layout_constraintTop_toBottomOf="@+id/text_nav_container"
                    app:shapeAppearanceOverlay="@style/RoundedCornersMedium"
                    app:strokeColor="#000000"
                    app:strokeWidth="2dp"
                    app:srcCompat="@drawable/m_promo" />

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/img_chicken"
                    android:layout_width="0dp"
                    android:layout_height="160dp"
                    android:layout_marginStart="8dp"
                    android:layout_marginTop="20dp"
                    android:elevation="6dp"
                    android:padding="2dp"
                    android:scaleType="centerCrop"
                    app:layout_constraintEnd_toEndOf="@id/banner_two"
                    app:layout_constraintStart_toEndOf="@+id/img_promo"
                    app:layout_constraintTop_toBottomOf="@+id/text_nav_container"
                    app:shapeAppearanceOverlay="@style/RoundedCornersMedium"
                    app:strokeColor="#000000"
                    app:strokeWidth="2dp"
                    app:srcCompat="@drawable/m_chickenmojo" />

                <!-- ROW 2 -->
                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/img_pizza"
                    android:layout_width="0dp"
                    android:layout_height="160dp"
                    android:layout_marginTop="16dp"
                    android:layout_marginEnd="8dp"
                    android:elevation="6dp"
                    android:padding="2dp"
                    android:scaleType="centerCrop"
                    app:layout_constraintEnd_toStartOf="@+id/img_pasta"
                    app:layout_constraintStart_toStartOf="@id/img_promo"
                    app:layout_constraintTop_toBottomOf="@+id/img_promo"
                    app:shapeAppearanceOverlay="@style/RoundedCornersMedium"
                    app:strokeColor="#000000"
                    app:strokeWidth="2dp"
                    app:srcCompat="@drawable/m_pizza" />

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/img_pasta"
                    android:layout_width="0dp"
                    android:layout_height="160dp"
                    android:layout_marginStart="8dp"
                    android:layout_marginTop="16dp"
                    android:elevation="6dp"
                    android:padding="2dp"
                    android:scaleType="centerCrop"
                    app:layout_constraintEnd_toEndOf="@id/img_chicken"
                    app:layout_constraintStart_toEndOf="@+id/img_pizza"
                    app:layout_constraintTop_toBottomOf="@+id/img_chicken"
                    app:shapeAppearanceOverlay="@style/RoundedCornersMedium"
                    app:strokeColor="#000000"
                    app:strokeWidth="2dp"
                    app:srcCompat="@drawable/m_pasta" />

                <!-- ROW 3 -->
                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/img_combo"
                    android:layout_width="0dp"
                    android:layout_height="160dp"
                    android:layout_marginTop="16dp"
                    android:layout_marginEnd="8dp"
                    android:elevation="6dp"
                    android:padding="2dp"
                    android:scaleType="centerCrop"
                    app:layout_constraintEnd_toStartOf="@+id/img_deals"
                    app:layout_constraintStart_toStartOf="@id/img_pizza"
                    app:layout_constraintTop_toBottomOf="@+id/img_pizza"
                    app:shapeAppearanceOverlay="@style/RoundedCornersMedium"
                    app:strokeColor="#000000"
                    app:strokeWidth="2dp"
                    app:srcCompat="@drawable/m_combo" />

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/img_deals"
                    android:layout_width="0dp"
                    android:layout_height="160dp"
                    android:layout_marginStart="8dp"
                    android:layout_marginTop="16dp"
                    android:elevation="6dp"
                    android:padding="2dp"
                    android:scaleType="centerCrop"
                    app:layout_constraintEnd_toEndOf="@id/img_pasta"
                    app:layout_constraintStart_toEndOf="@+id/img_combo"
                    app:layout_constraintTop_toBottomOf="@+id/img_pasta"
                    app:shapeAppearanceOverlay="@style/RoundedCornersMedium"
                    app:strokeColor="#000000"
                    app:strokeWidth="2dp"
                    app:srcCompat="@drawable/m_deals" />

                <!-- ROW 4 -->
                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/img_desserts"
                    android:layout_width="0dp"
                    android:layout_height="160dp"
                    android:layout_marginTop="16dp"
                    android:layout_marginEnd="8dp"
                    android:elevation="6dp"
                    android:padding="2dp"
                    android:scaleType="centerCrop"
                    app:layout_constraintEnd_toStartOf="@+id/img_drinks"
                    app:layout_constraintStart_toStartOf="@id/img_combo"
                    app:layout_constraintTop_toBottomOf="@+id/img_combo"
                    app:shapeAppearanceOverlay="@style/RoundedCornersMedium"
                    app:strokeColor="#000000"
                    app:strokeWidth="2dp"
                    app:srcCompat="@drawable/m_desserts" />

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/img_drinks"
                    android:layout_width="0dp"
                    android:layout_height="160dp"
                    android:layout_marginStart="8dp"
                    android:layout_marginTop="16dp"
                    android:elevation="6dp"
                    android:padding="2dp"
                    android:scaleType="centerCrop"
                    app:layout_constraintEnd_toEndOf="@id/img_deals"
                    app:layout_constraintStart_toEndOf="@+id/img_desserts"
                    app:layout_constraintTop_toBottomOf="@+id/img_deals"
                    app:shapeAppearanceOverlay="@style/RoundedCornersMedium"
                    app:strokeColor="#000000"
                    app:strokeWidth="2dp"
                    app:srcCompat="@drawable/m_drinks" />

                <!-- ROW 5 -->
                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/img_groupmeals"
                    android:layout_width="0dp"
                    android:layout_height="160dp"
                    android:layout_marginTop="16dp"
                    android:layout_marginEnd="8dp"
                    android:elevation="6dp"
                    android:padding="2dp"
                    android:scaleType="centerCrop"
                    app:layout_constraintEnd_toStartOf="@+id/img_salad"
                    app:layout_constraintStart_toStartOf="@id/img_desserts"
                    app:layout_constraintTop_toBottomOf="@+id/img_desserts"
                    app:shapeAppearanceOverlay="@style/RoundedCornersMedium"
                    app:strokeColor="#000000"
                    app:strokeWidth="2dp"
                    app:srcCompat="@drawable/m_groupmeals" />

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/img_salad"
                    android:layout_width="0dp"
                    android:layout_height="160dp"
                    android:layout_marginStart="8dp"
                    android:layout_marginTop="16dp"
                    android:elevation="6dp"
                    android:padding="2dp"
                    android:scaleType="centerCrop"
                    app:layout_constraintEnd_toEndOf="@id/img_drinks"
                    app:layout_constraintStart_toEndOf="@+id/img_groupmeals"
                    app:layout_constraintTop_toBottomOf="@+id/img_drinks"
                    app:shapeAppearanceOverlay="@style/RoundedCornersMedium"
                    app:strokeColor="#000000"
                    app:strokeWidth="2dp"
                    app:srcCompat="@drawable/m_salad" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.core.widget.NestedScrollView>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.drawerlayout.widget.DrawerLayout>