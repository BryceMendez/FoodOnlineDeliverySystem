<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <!-- STATUS STEPPER -->
    <LinearLayout
        android:id="@+id/stepperRow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingVertical="16dp"
        android:gravity="center_vertical"
        android:background="#FFFFFF"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Step 1: New -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <ImageView
                android:id="@+id/ivStepNew"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:src="@drawable/ic_step_new"
                android:background="@drawable/bg_step_done"
                android:padding="10dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="New"
                android:textColor="#BE1028"
                android:textStyle="bold"
                android:textSize="13sp" />
        </LinearLayout>

        <View
            android:layout_width="24dp"
            android:layout_height="2dp"
            android:background="#BE1028"
            android:layout_marginBottom="20dp" />

        <!-- Step 2: Preparing (Active) -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <ImageView
                android:id="@+id/ivStepPreparing"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:src="@drawable/ic_step_preparing"
                android:background="@drawable/bg_step_active"
                android:padding="10dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Preparing"
                android:textColor="#BE1028"
                android:textStyle="bold"
                android:textSize="13sp" />
        </LinearLayout>

        <View
            android:layout_width="24dp"
            android:layout_height="2dp"
            android:background="#CCCCCC"
            android:layout_marginBottom="20dp" />

        <!-- Step 3: Ready -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <ImageView
                android:id="@+id/ivStepReady"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:src="@drawable/ic_step_ready"
                android:background="@drawable/bg_step_inactive"
                android:padding="10dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Ready"
                android:textColor="#AAAAAA"
                android:textSize="13sp" />
        </LinearLayout>

        <View
            android:layout_width="24dp"
            android:layout_height="2dp"
            android:background="#CCCCCC"
            android:layout_marginBottom="20dp" />

        <!-- Step 4: Completed -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <ImageView
                android:id="@+id/ivStepCompleted"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:src="@drawable/ic_step_done"
                android:background="@drawable/bg_step_inactive"
                android:padding="10dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Completed"
                android:textColor="#AAAAAA"
                android:textSize="13sp" />
        </LinearLayout>
    </LinearLayout>

    <View
        android:id="@+id/dividerStepper"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#F0F0F0"
        app:layout_constraintTop_toBottomOf="@id/stepperRow" />

    <!-- SCROLLABLE CONTENT -->
    <ScrollView
        android:id="@+id/scrollContent"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/stepperRow"
        app:layout_constraintBottom_toTopOf="@id/bottomBar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="16dp">

            <!-- ORDER TICKET HEADER -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="20dp"
                android:paddingTop="20dp"
                android:paddingBottom="12dp"
                android:background="#FFFFFF">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ORDER TICKET"
                        android:textColor="#999999"
                        android:textSize="11sp"
                        android:letterSpacing="0.1" />

                    <TextView
                        android:id="@+id/tvOrderId"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="#482-B"
                        android:textColor="#BE1028"
                        android:textSize="32sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:orientation="vertical"
                    android:gravity="end">

                    <TextView
                        android:id="@+id/tvElapsedTime"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="14:22"
                        android:textColor="#BE1028"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:drawablePadding="6dp"
                        app:drawableStartCompat="@drawable/ic_timer"
                        app:drawableTint="#BE1028" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Elapsed Time"
                        android:textColor="#999999"
                        android:textSize="12sp" />
                </LinearLayout>
            </RelativeLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#F0F0F0" />

            <!-- ORDER ITEMS CONTAINER (populated by code) -->
            <LinearLayout
                android:id="@+id/llOrderItems"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#FFFFFF" />

            <!-- CUSTOMER INFO CARD -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardCustomerInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="12dp"
                app:cardCornerRadius="10dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFF0F0">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp">

                    <ImageView
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:src="@drawable/ic_person"
                        app:tint="#BE1028" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginStart="12dp">

                        <TextView
                            android:id="@+id/tvCustomerLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Table 12 • Mike R."
                            android:textColor="#1A1A1A"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvCustomerNote"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="Severe Peanut Allergy - Clean prep surface required."
                            android:textColor="#555555"
                            android:textSize="13sp" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ORDER DETAILS COLLAPSIBLE HEADER -->
            <TextView
                android:id="@+id/tvOrderDetailsToggle"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="12dp"
                android:background="#FFFFFF"
                android:gravity="center_vertical"
                android:paddingHorizontal="20dp"
                android:text="ORDER DETAILS"
                android:textColor="#1A1A1A"
                android:textSize="13sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:drawablePadding="8dp"
                app:drawableEndCompat="@drawable/ic_arrow_down" />

        </LinearLayout>
    </ScrollView>

    <!-- BOTTOM ACTION BAR -->
    <LinearLayout
        android:id="@+id/bottomBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:background="#FFFFFF"
        android:elevation="8dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPrint"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:layout_marginEnd="12dp"
            android:text="PRINT"
            android:textColor="#BE1028"
            android:textStyle="bold"
            android:textSize="14sp"
            app:cornerRadius="10dp"
            app:strokeColor="#BE1028"
            app:strokeWidth="2dp"
            app:icon="@drawable/ic_printer"
            app:iconTint="#BE1028"
            app:iconGravity="textStart" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnMarkAsReady"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="2"
            android:backgroundTint="#BE1028"
            android:text="MARK AS READY"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:textSize="14sp"
            app:cornerRadius="10dp"
            app:icon="@drawable/ic_step_ready"
            app:iconTint="#FFFFFF"
            app:iconGravity="textStart" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
